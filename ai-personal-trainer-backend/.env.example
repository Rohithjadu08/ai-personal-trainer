# ---- Auth ----
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_strong_random_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Database ----
# SQLite works on Render (ephemeral per deploy). Use postgres://... for persistence.
DATABASE_URL=sqlite:///./app.db

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- CORS ----
# Comma-separated allowed origins. Use "*" to allow any, or set your Vercel URL.
CORS_ORIGINS=*

# ---- Optional AI providers (not required for auth) ----
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here
OPENAI_API_KEY=your_openai_key_here

# ---- Camera / CV tuning ----
CAMERA_INDEX=0
